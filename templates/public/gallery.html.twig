{% extends 'base.html.twig' %}

{% block title %}{{ 'nav.gallery'|trans }} - {{ 'brand'|trans }}{% endblock %}
{% block meta_description %}{{ 'gallery.meta_description'|trans }}{% endblock %}
{% block canonical_url %}{{ url('app_gallery', {_locale: locale}) }}{% endblock %}
{% block og_image %}{{ absolute_url((featuredImage ? featuredImage.imageUrl : '/assets/bazma-hero.webp')|webp_image) }}{% endblock %}
{% block alternate_links %}
    <link rel="alternate" hreflang="ar" href="{{ url('app_gallery', {_locale: 'ar'}) }}">
    <link rel="alternate" hreflang="fr" href="{{ url('app_gallery', {_locale: 'fr'}) }}">
    <link rel="alternate" hreflang="en" href="{{ url('app_gallery', {_locale: 'en'}) }}">
{% endblock %}

{% block body %}
<header class="site-header compact">
    <a class="brand" href="{{ path('app_home', {_locale: locale}) }}">{{ 'brand'|trans }}</a>
    <nav>
        <a href="{{ path('app_home', {_locale: locale}) }}">{{ 'nav.home'|trans }}</a>
        <span class="locale-switch">
            <a class="{{ locale == 'ar' ? 'active' : '' }}" href="{{ path('app_gallery', {_locale: 'ar'}) }}">AR</a>
            <a class="{{ locale == 'fr' ? 'active' : '' }}" href="{{ path('app_gallery', {_locale: 'fr'}) }}">FR</a>
            <a class="{{ locale == 'en' ? 'active' : '' }}" href="{{ path('app_gallery', {_locale: 'en'}) }}">EN</a>
        </span>
    </nav>
</header>

<main class="gallery-page">
    <section class="section gallery-intro">
        <div class="gallery-intro-copy">
            <p class="eyebrow">{{ 'nav.gallery'|trans }}</p>
            <h1>{{ 'gallery.title'|trans }}</h1>
            <p>{{ 'gallery.intro'|trans }}</p>
        </div>
        <div class="gallery-stat">
            <strong>{{ images|length }}</strong>
            <span>{{ 'nav.gallery'|trans }}</span>
        </div>
    </section>

    {% if featuredImage %}
        <section class="section gallery-feature">
            <div class="gallery-feature-image">
                <img src="{{ featuredImage.imageUrl|webp_image }}" alt="{{ featuredImage.localizedTitle(locale) }}">
            </div>
            <div class="gallery-feature-content">
                <p class="eyebrow">{{ 'gallery.collection'|trans }}</p>
                <h2>{{ featuredImage.localizedTitle(locale) }}</h2>
                {% if featuredImage.credit %}
                    <p>{{ featuredImage.credit }}</p>
                {% endif %}
                {% if featuredImage.sourceUrl %}
                    <a class="button secondary gallery-source-button" href="{{ featuredImage.sourceUrl }}" target="_blank" rel="noreferrer">{{ 'gallery.source'|trans }}</a>
                {% endif %}
            </div>
        </section>
    {% endif %}

    <section class="section gallery-collection">
        <div class="gallery-section-head">
            <div>
                <p class="eyebrow">{{ 'gallery.collection'|trans }}</p>
                <h2>{{ 'gallery.collection_title'|trans }}</h2>
            </div>
            <span>{{ 'gallery.count'|trans({'%count%': images|length}) }}</span>
        </div>

        <div class="gallery-pro-grid">
            {% for image in images %}
                {% set title = image.localizedTitle(locale) %}
                <figure class="gallery-card">
                    <a class="gallery-card-media" href="{{ image.imageUrl|webp_image }}" target="_blank" rel="noreferrer" aria-label="{{ 'gallery.open'|trans({'%title%': title}) }}">
                        <img src="{{ image.imageUrl|webp_image }}" alt="{{ title }}" loading="{{ loop.index > 3 ? 'lazy' : 'eager' }}">
                    </a>
                    <figcaption class="gallery-card-body">
                        <span class="gallery-index">{{ loop.index < 10 ? '0' ~ loop.index : loop.index }}</span>
                        <strong>{{ title }}</strong>
                        {% if image.credit %}
                            <small>{{ image.credit }}</small>
                        {% endif %}
                        {% if image.sourceUrl %}
                            <a href="{{ image.sourceUrl }}" target="_blank" rel="noreferrer">{{ 'gallery.source'|trans }}</a>
                        {% endif %}
                    </figcaption>
                </figure>
            {% else %}
                <p class="gallery-empty">{{ 'gallery.empty'|trans }}</p>
            {% endfor %}
        </div>
    </section>
</main>
{% endblock %}
