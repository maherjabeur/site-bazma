<article class="archive-card {{ archived|default(false) ? 'is-archived' : '' }}">
    {% if event.imageUrl %}
        <img src="{{ event.imageUrl|webp_image }}" alt="{{ event.localizedTitle(locale) }}">
    {% endif %}
    <div>
        <span class="news-category">{{ event.category }}</span>
        <time>{{ event.eventDate ? event.eventDate|date('d/m/Y') : 'planned'|trans }}</time>
        <h3>{{ event.localizedTitle(locale) }}</h3>
        <p>{{ event.localizedExcerpt(locale) }}</p>
        <a href="{{ path('app_news_show', {_locale: locale, slug: event.slug}) }}">{{ 'read_more'|trans }}</a>
    </div>
</article>
