{% extends 'base.html.twig' %}

{% block title %}{{ page.localizedTitle(locale) }} - {{ 'brand'|trans }}{% endblock %}
{% block meta_description %}{{ page.localizedSummary(locale) }}{% endblock %}
{% block canonical_url %}{{ canonicalRoute|default(null) ? url(canonicalRoute, {_locale: locale}) : url('app_page', {_locale: locale, slug: page.slug}) }}{% endblock %}
{% block alternate_links %}
    {% if canonicalRoute|default(null) %}
        <link rel="alternate" hreflang="ar" href="{{ url(canonicalRoute, {_locale: 'ar'}) }}">
        <link rel="alternate" hreflang="fr" href="{{ url(canonicalRoute, {_locale: 'fr'}) }}">
        <link rel="alternate" hreflang="en" href="{{ url(canonicalRoute, {_locale: 'en'}) }}">
    {% else %}
        <link rel="alternate" hreflang="ar" href="{{ url('app_page', {_locale: 'ar', slug: page.slug}) }}">
        <link rel="alternate" hreflang="fr" href="{{ url('app_page', {_locale: 'fr', slug: page.slug}) }}">
        <link rel="alternate" hreflang="en" href="{{ url('app_page', {_locale: 'en', slug: page.slug}) }}">
    {% endif %}
{% endblock %}
{% block og_type %}article{% endblock %}
{% block og_image %}{{ absolute_url((page.imageUrl ?: '/assets/bazma-hero.webp')|webp_image) }}{% endblock %}

{% block body %}
<header class="site-header compact">
    <a class="brand" href="{{ path('app_home', {_locale: locale}) }}">{{ 'brand'|trans }}</a>
    <nav>
        <a href="{{ path('app_gallery', {_locale: locale}) }}">{{ 'nav.gallery'|trans }}</a>
        <span class="locale-switch">
            <a class="{{ locale == 'ar' ? 'active' : '' }}" href="{{ canonicalRoute|default(null) ? path(canonicalRoute, {_locale: 'ar'}) : path('app_page', {_locale: 'ar', slug: page.slug}) }}">AR</a>
            <a class="{{ locale == 'fr' ? 'active' : '' }}" href="{{ canonicalRoute|default(null) ? path(canonicalRoute, {_locale: 'fr'}) : path('app_page', {_locale: 'fr', slug: page.slug}) }}">FR</a>
            <a class="{{ locale == 'en' ? 'active' : '' }}" href="{{ canonicalRoute|default(null) ? path(canonicalRoute, {_locale: 'en'}) : path('app_page', {_locale: 'en', slug: page.slug}) }}">EN</a>
        </span>
    </nav>
</header>
<main class="article-page">
    {% if page.imageUrl %}
        <img class="article-hero" src="{{ page.imageUrl|webp_image }}" alt="{{ page.title }}">
    {% endif %}
    <article class="article-body">
        <p class="eyebrow">{{ 'article.discover'|trans }}</p>
        <h1>{{ page.localizedTitle(locale) }}</h1>
        <p class="lead">{{ page.localizedSummary(locale) }}</p>
        <div class="rich-text">{{ page.localizedBody(locale)|rich_content }}</div>
        {% if media is defined and media|length %}
            <section class="article-media">
                <h2>Médiathèque</h2>
                <div class="gallery-grid">
                    {% for item in media %}
                        <figure>
                            <img src="{{ item.imageUrl|webp_image }}" alt="{{ item.title }}">
                            <figcaption><strong>{{ item.title }}</strong>{% if item.caption %}<span>{{ item.caption }}</span>{% endif %}</figcaption>
                        </figure>
                    {% endfor %}
                </div>
            </section>
        {% endif %}
    </article>
</main>
{% endblock %}
